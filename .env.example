# Скопируй в .env.local и замени значения на что-то личное!
# Это и есть «логин» и «пароль» для входа на сайт.
#
# Примеры личных значений:
#   VITE_AUTH_LOGIN=кличка питомца / дата первого сообщения / место встречи
#   VITE_AUTH_PASSWORD=любимый фильм / секретное слово / памятная дата
#
# ВАЖНО: .env.local добавлен в .gitignore — эти данные не попадут в репозиторий.

VITE_AUTH_LOGIN=dev
VITE_AUTH_PASSWORD=dev
